    "husky": "^9.1.7",
    "i18n-js": "^4.5.3",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "pnpm": {
    "overrides": {
      "write-file-atomic": "^5.0.0"
    }
  },
  "packageManager": "pnpm@10.28.1",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:app": "jest --runInBand src/app",
    "test:app:coverage": "jest --runInBand --coverage --no-cache src/app",
    "test:app:parity": "node scripts/test-app-parity.mjs",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e:parity": "node scripts/e2e-route-parity.mjs",
    "e2e:android": "maestro test .maestro/suites/all-pages.yaml",
    "e2e:android:ci": "maestro test --format junit --output .maestro/results .maestro/suites/all-pages.yaml",
    "skill:heroui:test": "node --test --experimental-test-isolation=none .windsurf/skills/heroui-native/scripts/__tests__/*.test.mjs",
    "skill:heroui:validate": "node .windsurf/skills/heroui-native/scripts/validate_skill.mjs",
    "skill:heroui:smoke": "node .windsurf/skills/heroui-native/scripts/list_components.mjs --format text && node .windsurf/skills/heroui-native/scripts/get_component_docs.mjs Button --format text && node .windsurf/skills/heroui-native/scripts/get_docs.mjs /docs/native/getting-started/theming --format text && node .windsurf/skills/heroui-native/scripts/get_theme.mjs --format text",
    "skill:heroui:check": "pnpm run skill:heroui:validate && pnpm run skill:heroui:test",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/patch-fitsjs.mjs",
    "prepare": "husky"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-zip-archive"
        ]
      }
    }
  }
}
